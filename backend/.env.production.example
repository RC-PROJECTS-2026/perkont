# ─── Uygulama ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_NAME=PerKont
APP_VERSION=1.0.0
FRONTEND_URL=https://app.perkont.com
API_URL=https://api.perkont.com/api/v1

# ─── Veritabanı ───────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=perkont_user
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD_MIN_32_CHARS
DB_DATABASE=perkont_production
DB_SSL=false
DB_LOGGING=false
DB_MAX_CONNECTIONS=20

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_DB=0
REDIS_TTL=3600

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Minimum 64 karakter rastgele string kullanın
# Üretmek için: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_MINIMUM_64_CHARACTER_RANDOM_STRING_FOR_JWT_ACCESS_TOKEN
JWT_REFRESH_SECRET=CHANGE_ME_MINIMUM_64_CHARACTER_RANDOM_STRING_FOR_JWT_REFRESH_TOKEN
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Şifreleme ────────────────────────────────────────────────────────────────
# Tam olarak 32 karakter olmalı
# Üretmek için: openssl rand -base64 32 | head -c 32
ENCRYPTION_KEY=CHANGE_ME_EXACTLY_32_CHARS_ENCRYPTION

# ─── MinIO / S3 ───────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=perkont_minio_access
MINIO_SECRET_KEY=CHANGE_ME_STRONG_MINIO_SECRET
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_PHOTOS=inspection-photos
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_ARCHIVE=signed-reports-archive
MINIO_REGION=eu-central-1

# ─── E-posta (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@perkont.com
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM_NAME=PerKont Bildirim
SMTP_FROM_EMAIL=noreply@perkont.com

# ─── SMS (Netgsm) ─────────────────────────────────────────────────────────────
NETGSM_USERCODE=CHANGE_ME_NETGSM_USERCODE
NETGSM_PASSWORD=CHANGE_ME_NETGSM_PASSWORD
NETGSM_MSGHEADER=PERKONT
NETGSM_API_URL=https://api.netgsm.com.tr/sms/send/xml

# ─── E-İmza (TürkTrust) ───────────────────────────────────────────────────────
# Geliştirme için ESIGN_PROVIDER=mock kullanın
ESIGN_PROVIDER=mock
TURKTRUST_API_URL=https://api.turktrust.com.tr/esign
TURKTRUST_API_KEY=CHANGE_ME_TURKTRUST_API_KEY
TURKTRUST_CUSTOMER_ID=CHANGE_ME_TURKTRUST_CUSTOMER_ID
TURKTRUST_CERTIFICATE_PATH=/app/certs/turktrust.p12
TURKTRUST_CERTIFICATE_PASSWORD=CHANGE_ME_CERTIFICATE_PASSWORD

# ─── LOGO ERP ─────────────────────────────────────────────────────────────────
LOGO_API_URL=http://logo-server:8081
LOGO_API_USERNAME=CHANGE_ME_LOGO_USERNAME
LOGO_API_PASSWORD=CHANGE_ME_LOGO_PASSWORD
LOGO_FIRM_NUMBER=1
LOGO_PERIOD_NUMBER=1
LOGO_WAREHOUSE_NUMBER=0
LOGO_ENABLED=true

# ─── Loglama ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ─── Güvenlik ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://app.perkont.com
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30

# ─── MFA ──────────────────────────────────────────────────────────────────────
MFA_APP_NAME=PerKont
MFA_ISSUER=PerKont Akreditasyon

# ─── Müşteri Portali ──────────────────────────────────────────────────────────
PORTAL_ENABLED=true
PORTAL_URL=https://portal.perkont.com

# ─── BullMQ ───────────────────────────────────────────────────────────────────
BULL_LOGO_QUEUE_CONCURRENCY=2
BULL_NOTIFICATION_QUEUE_CONCURRENCY=5

# ─── Özellik Bayrakları ───────────────────────────────────────────────────────
FEATURE_ESIGN_ENABLED=false
FEATURE_LOGO_ENABLED=true
FEATURE_SMS_ENABLED=true
FEATURE_PORTAL_ENABLED=true

# ─── REDIS SENTINEL (Bölüm 13) ───────────────────────────────────────────────
REDIS_SENTINEL_HOSTS=perkont-redis-sentinel-1:26379,perkont-redis-sentinel-2:26379,perkont-redis-sentinel-3:26379
REDIS_SENTINEL_NAME=perkont-master

# ─── POSTGRESQL REPLICATION (Bölüm 13) ───────────────────────────────────────
DB_REPLICATION_PASSWORD=strong_replication_password_here

# ─── PGBACKUP / S3 (Bölüm 13 — 90 gün saklama) ───────────────────────────────
BACKUP_S3_BUCKET=perkont-backups
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ENDPOINT=http://minio:9000
BACKUP_ENCRYPTION_PASSWORD=strong_backup_encryption_password_here

# ─── ELK STACK (Bölüm 12) ────────────────────────────────────────────────────
LOGSTASH_HOST=perkont-logstash
LOGSTASH_PORT=5000
ELASTIC_PASSWORD=strong_elastic_password_here
KIBANA_PASSWORD=strong_kibana_password_here
