# APPLICATION
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3001

# DATABASE (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_mysql_password
DB_DATABASE=perkont_db
DB_LOGGING=false

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_32ch
JWT_REFRESH_EXPIRES_IN=7d

# MINIO / S3
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key
MINIO_BUCKET_DOCUMENTS=perkont-documents
MINIO_BUCKET_PHOTOS=perkont-photos
MINIO_BUCKET_REPORTS=perkont-reports
MINIO_BUCKET_ARCHIVE=perkont-archive

# EMAIL (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@firma.com
SMTP_PASS=smtp_password
SMTP_FROM="PerKont Sistemi <noreply@firma.com>"

# SMS (Netgsm)
SMS_PROVIDER=netgsm
SMS_API_KEY=sms_api_key
SMS_API_SECRET=sms_api_secret
SMS_SENDER=FIRMA

# LOGO ERP
LOGO_BASE_URL=http://logo-server:8080
LOGO_USERNAME=logo_user
LOGO_PASSWORD=logo_password
LOGO_FIRM_NUMBER=001
LOGO_PERIOD_NUMBER=01

# E-IMZA
ESIGN_PROVIDER=mock
ESIGN_API_URL=https://api.esign-provider.com
ESIGN_API_KEY=esign_api_key
ESIGN_API_SECRET=esign_api_secret

# REPORT VERIFICATION
REPORT_VERIFY_BASE_URL=https://verify.firma.com

# MFA
MFA_APP_NAME=PerKont
MFA_ISSUER=PerKont Sistemi

# RATE LIMITING
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ENCRYPTION
ENCRYPTION_KEY=32_char_encryption_key_here_xxxxx

# LOGGING
LOG_LEVEL=info
LOG_FILE_PATH=./logs
